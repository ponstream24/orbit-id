{
  "name": "@orbit-id/core",
  "version": "1.1.0",
  "description": "Orbit ID v1 reference core (encode, decode, generator)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orbit-id/orbit-id.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/orbit-id/orbit-id/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/orbit-id/orbit-id/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
